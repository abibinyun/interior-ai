# interior-ai homelab-public deploy env (TEMPLATE — copy to `.env.homelab-public`)
# Same pattern as /home/abibinyun/data/LATIHAN/auto-payment/.env.homelab-public

# ── Public host ─────────────────────────────────────────────────
INTERIOR_DOMAIN=interior.cube.my.id

# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=interior

# ── Session ─────────────────────────────────────────────────────
SESSION_COOKIE_SECRET=
# Secure: auto (default) = trust X-Forwarded-Proto from Traefik
SESSION_COOKIE_SECURE=auto
TRUST_PROXY=true

# ── AI Provider ──────────────────────────────────────────────────
AI_PROVIDER=ai-horde
AI_PRIMARY_BASE_URL=https://gen.pollinations.ai
AI_FALLBACK_BASE_URL=https://api.myceli.ai
AI_PRIMARY_API_KEY=
AI_FALLBACK_API_KEY=
AI_HORDE_BASE_URL=https://stablehorde.net/api
AI_HORDE_API_KEY=

# ── Supabase storage ────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=generations
SIGNED_URL_TTL_SECONDS=900

# ── Rate limit ──────────────────────────────────────────────────
RATE_LIMIT_GENERATIONS_MAX=50
RATE_LIMIT_GENERATIONS_WINDOW_MS=60000
RATE_LIMIT_DISABLED=false

# ── Pipeline ────────────────────────────────────────────────────
GENERATION_TIMEOUT_MS=60000
GENERATION_HARD_TIMEOUT_MS=120000
ENABLE_GENERATION_AUTO_TRIGGER=true

# ── Metadata ────────────────────────────────────────────────────
APP_VERSION=homelab
LOG_LEVEL=info
MAX_REQUEST_BODY_BYTES=102400
