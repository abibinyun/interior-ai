# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://interior:interior@postgres:5432/interior?schema=public

# Session / CORS
SESSION_COOKIE_NAME=sid
SESSION_COOKIE_SECRET=change-me-in-prod-min-32-chars-ok
CORS_ORIGINS=http://localhost:5173

# AI Provider (ADR-002)
# ──────────────────────────────────────────────────────────────────
# Active provider selected by AI_PROVIDER. The other two remain
# registered so the pipeline orchestrator can use them as the AI-07
# fallback when the primary fails with a transient error (timeout,
# 5xx, or 402/429).
#
# Options:
#   pollinations (default) — synchronous GET → image bytes
#   myceli                 — synchronous POST → image bytes
#   ai-horde               — async submit + poll → image bytes
#   replicate              — async prediction API, Flux 2 Pro ($10 free)
#
# Provider keys are passed via the appropriate _API_KEY var below
# (gitignored in .env). Leave empty to use anonymous tiers.
# ──────────────────────────────────────────────────────────────────
AI_PROVIDER=pollinations
AI_PRIMARY_BASE_URL=https://gen.pollinations.ai
AI_FALLBACK_BASE_URL=https://api.myceli.ai
AI_PRIMARY_API_KEY=
AI_FALLBACK_API_KEY=
# AI Horde (https://stablehorde.net/) — async submit + poll API.
# Register a free key at https://stablehorde.net/register to skip
# the anonymous (abyssal) queue. The key is sent via the `apikey`
# header, NOT as a Bearer token.
AI_HORDE_BASE_URL=https://stablehorde.net/api
AI_HORDE_API_KEY=
# Replicate (https://replicate.com/) — async prediction API.
# Default model: Flux 2 Pro (black-forest-labs/flux-2-pro),
# ~9s per generation. $10 free credits on signup.
# Register at https://replicate.com/signin and get a token.
REPLICATE_API_KEY=
REPLICATE_MODEL=black-forest-labs/flux-2-pro
GENERATION_TIMEOUT_MS=60000
GENERATION_HARD_TIMEOUT_MS=120000

# Storage (ADR-012)
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=generations
SIGNED_URL_TTL_SECONDS=900

# Rate limiting (ADR-013)
# ──────────────────────────────────────────────────────────────────
# The "generations" limiter covers AI-touching endpoints
# (`/api/rooms/:id/generations*` + `/api/rooms/:id/approval`) because
# each call hits the provider + storage. Both knobs are tunable per
# environment:
#
#   MAX     — request count per window (default 5)
#   WINDOW  — window length in ms (default 60000 = 60s)
#
# Foot-gun guard: MAX must be at least 3, otherwise the
# POST-create + immediate GET-list refetch + first batch poll cycle
# will trip the limiter on a normal user flow. The schema enforces
# this at boot with a clear error.
#
# Disable the limiter entirely (useful for tests, benchmarks, demos):
#
#   RATE_LIMIT_DISABLED=true
#
# Operators can confirm the active config in the backend boot log:
#   "RateLimitConfig  generations limiter: max=5 per 60000ms (~60s window)"
# ──────────────────────────────────────────────────────────────────
RATE_LIMIT_GENERATIONS_MAX=5
RATE_LIMIT_GENERATIONS_WINDOW_MS=60000
# Maximum JSON request body size in bytes (M17 hardening)
MAX_REQUEST_BODY_BYTES=102400
# Set to 'true' to bypass the rate limiter (tests / benchmarks)
RATE_LIMIT_DISABLED=false

# Frontend (F1) — Vite dev proxy target. In Docker compose this is
# overridden to http://backend:3000; for local development without
# Docker, set it to http://localhost:3000 (the default).
VITE_API_TARGET=http://localhost:3000
